      "uco-core:description": {
        "@type": "xsd:string",
        "@value": "Federal RICO social-engineering enterprise prosecution in U.S. District Court, District of Columbia. Minimum 9 named victims; 17 defendants on docket. Operational window 2023-10 to 2025-05. Alleged loss at least USD 263,000,000."
      },
