    {
      "@id": "kb:racketeering-1-24-cr-00417-ckk-indictment",
      "@type": "cacontology:MultiDefendantIndictment",
      "uco-core:name": "PACER D.D.C. 1:24-cr-00417-CKK \u2014 docket; Doc 245 Second Superseding Indictment; Tangeman sentencing memorandum",
