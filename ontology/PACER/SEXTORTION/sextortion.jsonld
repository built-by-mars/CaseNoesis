      "uco-core:name": "U.S. v. Defendant-1 \u2014 3:22-cr-00055-SLG-KFR",
      "uco-core:description": {
        "@type": "xsd:string",
        "@value": "Federal prosecution in U.S. District Court, District of Alaska. Approximately 30 alleged victims (minimum age 11). Charge stacking observed: financial and identity statutes used to reach csea conduct. Ban evasion alleged: 80+ Snapchat accounts and 40+ Instagram accounts recreated after platform enforcement."
      },
      "case-investigation:focus": [
        "Child Sexual Exploitation Enterprise",
        "Sextortion",
        "CSAM Production and Distribution",
