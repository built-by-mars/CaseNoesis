<https://caselinker.up.railway.app/resource/case/doj_ceos_2025_023/admission/1> a cacontology-undercover:IncriminatingStatement ;
    rdfs:label "engaging in sexually explicit conduct with at least one minor for the purpose of producing a visual depiction of that..." ;
    dcterms:source <https://www.justice.gov/opa/pr/kentucky-man-sentenced-sexually-exploiting-minors-philippines> ;
    ns1:admissionContext "sic necessities for the minors, who lived in desperate circumstances. As part of his plea agreement, Werner admitted to engaging in sexua..." ;
    ns1:admissionFrame "admitted_to" ;
    ns1:admissionTheme "harm_conduct" ;
    ns1:attributedToOffenderRole <https://caselinker.up.railway.app/resource/case/doj_ceos_2025_023/role/offender/1> ;
    ns1:evidenceTier "press_release_stated" ;
    ns1:quoteType "paraphrase" ;
    uco-core:description "engaging in sexually explicit conduct with at least one minor for the purpose of producing a visual depiction of that conduct between July 2021 and November 2021, while in the Philippines" .

<https://caselinker.up.railway.app/resource/case/doj_ceos_2025_023/admission/2> a cacontology-undercover:IncriminatingStatement ;
    rdfs:label "transporting that sexually explicit material into the United States" ;
