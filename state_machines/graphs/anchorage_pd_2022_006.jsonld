    {
      "@id": "caselinker:anchorage_pd_2022_006-phase-multi-victim-enterprise",
      "@type": "cac-grooming:MaintenancePhase",
      "rdfs:label": "Multi-Victim HU$H Enterprise",
      "rdfs:comment": "Sustained trafficking of J.S. and K.C. through December 2018; at least three sexually explicit videos involving J.S. branded with HU$H logo; firearms and drugs used to control victims (indictment ¶32, 409-410; findings Counts 6-8)",
