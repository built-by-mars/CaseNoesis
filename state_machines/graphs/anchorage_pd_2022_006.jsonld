      "@id": "caselinker:anchorage_pd_2022_006-phase-commercial-operation",
      "@type": "cac-grooming:ExploitationPhase",
      "rdfs:label": "Adultlook Commercial Sex Operation",
      "rdfs:comment": "Mid-October through December 2018 — Adultlook ads and phone/text customer booking; in-calls, out-calls, and car dates in Anchorage; Grant transported J.S., collected proceeds, and coordinated minor-status customer extortion (indictment ¶16-23, 27-29; findings Counts 2-5)",
      "cac-core:precedes": {
        "@id": "caselinker:anchorage_pd_2022_006-phase-multi-victim-enterprise"
