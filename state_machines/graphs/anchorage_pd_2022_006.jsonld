      "@id": "caselinker:anchorage_pd_2022_006-phase-adultlook-migration",
      "@type": "cac-platforms:ChannelMigrationEvent",
      "rdfs:label": "Phone/Text → Adultlook.com Listings",
      "rdfs:comment": "Grant and Banks assisted K.C. with an Adultlook.com prostitution profile under moniker Lady Silky; interstate commercial sex advertisements posted from mobile devices (indictment ¶7-8, 28)",
      "cac-platforms:fromPlatform": "SMS / cellular",
      "cac-platforms:toPlatform": "Adultlook.com",
      "cac-platforms:migrationRationale": "commercial_customer_acquisition",
