        "cac-grooming:ConditioningPhase",
        "cac-core:Phase"
      ],
      "rdfs:label": "Harboring & Co-Pimping Control",
      "rdfs:comment": "Grant and Banks harbored homeless and transient minors at Banks' Anchorage apartment, provided maintenance, and recruited them toward commercial sex through romance manipulation and co-pimping control (indictment ¶14-15; findings Count 1)",
      "cac-core:precedes": {
        "@id": "caselinker:anchorage_pd_2022_006-phase-adultlook-migration"
      },
      "cac-core:conditioningMode": "trust_rapport"
