      "@type": "cac-grooming:InitialContactPhase",
      "rdfs:label": "Banks Network & Minor Victim Onset",
      "rdfs:comment": "September or October 2018 — Grant met J.S. through co-conspirator Banks; J.S. disclosed her age; K.C. introduced October or November 2018 and Grant learned her age (indictment ¶3-4; findings)",
      "cac-core:precedes": {
        "@id": "caselinker:anchorage_pd_2022_006-phase-harboring-control"
      }
    },
    {
      "@id": "caselinker:anchorage_pd_2022_006-phase-harboring-control",
