      "@type": "cac-grooming:InitialContactPhase",
      "rdfs:label": "Text & Email Contact with Minor 1",
      "rdfs:comment": "July 2023 — defendant began communicating with 12-year-old Minor 1 in Eastern District of Virginia via text and email (statement of facts ¶1)",
      "cac-core:precedes": {"@id": "caselinker:doj_ceos_2025_004-phase-trust-building"}
    },
    {
      "@id": "caselinker:doj_ceos_2025_004-phase-trust-building",
      "@type": "cac-grooming:TrustBuildingPhase",
      "rdfs:label": "Authority Grooming & Obedience Framing",
      "rdfs:comment": "July through September 24, 2023 — sexualized commands and compliance praise establishing defendant authority over Minor 1 in interstate text and email (statement of facts ¶1–¶2)",
      "cac-core:precedes": {"@id": "caselinker:doj_ceos_2025_004-phase-recording-solicitation"}
    },
