      "@id": "caselinker:doj_ceos_2025_004-phase-recording-solicitation",
      "@type": "cac-grooming:SexualizationPhase",
      "rdfs:label": "Directed Recording Solicitation",
      "rdfs:comment": "September 25, 2023 — defendant ordered Minor 1 to undress, perform sexually explicit conduct, and record it; first compliance and apparent file transfer in message thread (statement of facts ¶2; charged attempted production Count 1 dismissed at plea)",
      "cac-core:precedes": {"@id": "caselinker:doj_ceos_2025_004-phase-active-enticement"}
    },
    {
      "@id": "caselinker:doj_ceos_2025_004-phase-active-enticement",
      "@type": "cac-grooming:ExploitationPhase",
      "rdfs:label": "Active Enticement Through First Compliance",
      "rdfs:comment": "September 25, 2023 — defendant knowingly induced and enticed Minor 1 to engage in sexual activity via sexualized commands, obedience demands, directed recording, and post-compliance validation (statement of facts ¶1–¶2; Virginia Code § 18.2-370 predicate)",
      "cac-core:precedes": {"@id": "caselinker:doj_ceos_2025_004-phase-post-compliance-thread"}
    },
