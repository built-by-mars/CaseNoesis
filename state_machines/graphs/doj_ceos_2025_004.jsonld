      "@id": "caselinker:doj_ceos_2025_004-phase-post-compliance-thread",
      "@type": "cac-grooming:MaintenancePhase",
      "rdfs:label": "Post-Compliance Enticement Thread",
      "rdfs:comment": "Late September through October 30, 2023 — continued interstate text and email inducement after Sept 25 compliance gate; sustains authority-based enticement through charged conduct window (statement of facts ¶1; indictment Count 2)",
      "cac-core:precedes": {"@id": "caselinker:doj_ceos_2025_004-phase-terminal"}
    },
