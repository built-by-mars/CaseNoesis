    {
      "@id": "caselinker:doj_ceos_2025_023-phase-facilitator-contact",
      "@type": "cac-grooming:InitialContactPhase",
      "rdfs:label": "Facilitator Contact in Philippines",
      "rdfs:comment": "February 2021 — U.S. citizen living in Philippines came into contact with Facilitator who sold access to minor males for CSAM, livestream, and in-person sexual acts (plea agreement ¶3(a))",
      "cac-core:precedes": {"@id": "caselinker:doj_ceos_2025_023-phase-financial-grooming"}
    },
    {
      "@id": "caselinker:doj_ceos_2025_023-phase-financial-grooming",
      "@type": "cac-grooming:TrustBuildingPhase",
      "rdfs:label": "Paid CSAM Access & Financial Grooming",
      "rdfs:comment": "July 27, 2021 onward — encrypted messaging and Google Drive links; money for explicit images and videos; selection of underage boys; pizza money and essentials exchanged before in-person encounters (plea ¶3(a)-(b); sentencing memorandum)",
      "cac-core:precedes": {"@id": "caselinker:doj_ceos_2025_023-phase-commissioned-production"}
    },
    {
      "@id": "caselinker:doj_ceos_2025_023-phase-commissioned-production",
      "@type": "cac-grooming:SexualizationPhase",
      "rdfs:label": "Commissioned Remote Production",
      "rdfs:comment": "July–November 2021 — defendant paid for minor boys to engage in sexually explicit conduct; videos and images uploaded to password-protected Google Drive and sent via encrypted messaging; livestreamed conduct (plea ¶3(b))",
      "cac-core:precedes": {"@id": "caselinker:doj_ceos_2025_023-phase-hands-on-abuse"}
    },
    {
      "@id": "caselinker:doj_ceos_2025_023-phase-hands-on-abuse",
      "@type": "cac-grooming:ExploitationPhase",
      "rdfs:label": "In-Person Hands-On Abuse",
      "rdfs:comment": "Late August–September 2021 — four hotel encounters plus pool-house party; defendant engaged in sexual acts with minors including oral sex; narrated encounters while Facilitator staged additional boys (plea ¶3(a); sentencing memorandum)",
      "cac-core:precedes": {"@id": "caselinker:doj_ceos_2025_023-phase-transport-maintenance"}
    },
    {
      "@id": "caselinker:doj_ceos_2025_023-phase-transport-maintenance",
      "@type": "cac-grooming:MaintenancePhase",
      "rdfs:label": "Transport & Continued Solicitation",
      "rdfs:comment": "November 2021 — defendant transported depictions to United States on cell phone; continued paying for CSAM while traveling and after return to Walton, Kentucky (plea ¶3(c); sentencing memorandum Dec 2021 thread)",
      "cac-core:precedes": {"@id": "caselinker:doj_ceos_2025_023-phase-terminal"}
    },
    {
      "@id": "caselinker:doj_ceos_2025_023-phase-terminal",
      "@type": "cac-grooming:ExploitationPhase",
      "rdfs:label": "Persistent Transnational CSAM Archive",
      "rdfs:comment": "Terminal state — commissioned and in-person-produced depictions retained on devices carried to Eastern District of Kentucky; harm persists for multiple unidentified minor victims",
      "caselinker:is_terminal": true
    },
    {
