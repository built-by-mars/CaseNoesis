      "@type": "cac-grooming:InitialContactPhase",
      "rdfs:label": "Parallel Site Rank Acquisition",
      "rdfs:comment": "2022 — defendant acquired administrator rank on Website B (570+ posts) and global moderator status on Websites C and D while maintaining Website A operations (sentencing memorandum; PSR ¶¶9-11)",
      "cac-core:precedes": {
        "@id": "caselinker:doj_ceos_2025_025-phase-global-moderation"
