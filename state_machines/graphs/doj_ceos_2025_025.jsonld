      "@type": "cac-grooming:InitialContactPhase",
      "rdfs:label": "Website A Administrator Onset",
      "rdfs:comment": "January 2021 — defendant became administrator of Website A, a dark-web site dedicated to advertisement and distribution of child sexual abuse material; 500+ posts including indictment counts 1–3 conduct (sentencing memorandum; PSR ¶¶7-8)",
      "cac-core:precedes": {
        "@id": "caselinker:doj_ceos_2025_025-phase-multi-site-ranks"
      }
    },
