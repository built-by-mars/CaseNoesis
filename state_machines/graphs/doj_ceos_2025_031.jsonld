      "@type": "cac-platforms:AffordanceMisuse",
      "cac-platforms:enablesTransitionFrom": {"@id": "caselinker:doj_ceos_2025_031-phase-staff-coaching"},
      "cac-platforms:enablesTransitionTo": {"@id": "caselinker:doj_ceos_2025_031-phase-tiered-migration"},
