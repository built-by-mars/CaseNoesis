      "rdfs:label": "United States v. McIntosh & Katsampes · S.D. Fla. 9:24-cr-80053 · Operation Grayskull · 18 U.S.C. §§ 2251(d),(e); 2252A",
      "cacontology:hasStep": [
        {"@id": "caselinker:doj_ceos_2025_031-phase-forum-registration"},
