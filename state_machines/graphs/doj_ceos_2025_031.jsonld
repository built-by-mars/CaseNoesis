    {
      "@id": "caselinker:doj_ceos_2025_031-phase-forum-registration",
      "@type": "cac-grooming:InitialContactPhase",
      "rdfs:label": "Dark Web Forum Registration",
      "rdfs:comment": "Website A — 100+ registered members; public-facing chatroom for CP discussion and link trading; launched ~2017",
      "cac-core:precedes": {
        "@id": "caselinker:doj_ceos_2025_031-phase-promotion-ladder"
      }
    },
    {
      "@id": "caselinker:doj_ceos_2025_031-phase-promotion-ladder",
      "@type": "cac-grooming:InitialContactPhase",
      "rdfs:label": "Enterprise Promotion Ladder",
      "rdfs:comment": "Membership and moderator status earned by sharing CP; McIntosh voted on promotions; Katsampes elevated Nov 2022 after sustained posting",
      "cac-core:precedes": {
        "@id": "caselinker:doj_ceos_2025_031-phase-staff-coaching"
      }
    },
    {
      "@id": "caselinker:doj_ceos_2025_031-phase-staff-coaching",
      "@type": [
        "cac-grooming:ConditioningPhase",
        "cac-core:Phase"
      ],
      "rdfs:label": "Staff Training & On-Topic Coaching",
      "rdfs:comment": "Head-admin trained Katsampes on moderator shifts; coaching lower-ranking users on compliant CP sharing; McIntosh developed FAQ and backed up room data",
      "cac-core:precedes": {
        "@id": "caselinker:doj_ceos_2025_031-phase-tiered-migration"
      },
      "cac-core:conditioningMode": "platform_confidence"
    },
    {
      "@id": "caselinker:doj_ceos_2025_031-phase-tiered-migration",
      "@type": "cac-platforms:ChannelMigrationEvent",
      "rdfs:label": "Tiered Room Migration",
      "rdfs:comment": "Public chatroom → members-only → specialized topic rooms (age/topic gated); access earned by additional CP posts",
      "cac-platforms:fromPlatform": "Website A public rooms",
      "cac-platforms:toPlatform": "Website A members-only & specialized rooms",
      "cac-platforms:migrationRationale": "capability_upgrade",
      "cac-platforms:occursBetween": [
        {
          "@id": "caselinker:doj_ceos_2025_031-phase-staff-coaching"
        },
        {
          "@id": "caselinker:doj_ceos_2025_031-phase-link-distribution"
        }
      ],
      "cac-core:precedes": {
        "@id": "caselinker:doj_ceos_2025_031-phase-link-distribution"
      }
    },
    {
      "@id": "caselinker:doj_ceos_2025_031-phase-link-distribution",
      "@type": "cac-grooming:ExploitationPhase",
      "rdfs:label": "Link-Based CP Distribution",
      "rdfs:comment": "Tagged link posts redirect to file-host contact sheets; tens or hundreds of thousands of images/videos circulated; Katsampes June–Oct 2022 distribution incidents",
      "cac-core:precedes": {
        "@id": "caselinker:doj_ceos_2025_031-phase-gated-moderation"
      }
    },
    {
      "@id": "caselinker:doj_ceos_2025_031-phase-gated-moderation",
      "@type": "cac-grooming:MaintenancePhase",
      "rdfs:label": "Gated Repository Moderation",
      "rdfs:comment": "Moderators enforce on-topic rules, mute users, and gate interior repositories; McIntosh monitored donation email and admin voting room",
      "cac-core:precedes": {
        "@id": "caselinker:doj_ceos_2025_031-phase-opsec-culture"
      }
    },
    {
      "@id": "caselinker:doj_ceos_2025_031-phase-opsec-culture",
      "@type": "cac-sextortion:ThreatMechanism",
      "rdfs:label": "OPSEC & LE-Avoidance Culture",
      "rdfs:comment": "Dedicated evasion chatroom; McIntosh warned staff to treat all users as potential LE; encryption used to conceal activity",
      "cac-core:precedes": {
        "@id": "caselinker:doj_ceos_2025_031-phase-terminal-exploitation"
      }
    },
    {
      "@id": "caselinker:doj_ceos_2025_031-phase-terminal-exploitation",
      "@type": "cac-grooming:ExploitationPhase",
      "rdfs:label": "Persistent Distributed Archive",
      "rdfs:comment": "Terminal state — CP persists across file-host infrastructure and seized devices; post-Nov 2022 migration to successor dark-web sites until arrests"
    },
