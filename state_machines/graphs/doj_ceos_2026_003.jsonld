    {
      "@id": "caselinker:doj_ceos_2026_003-phase-residence-access",
      "@type": "cac-grooming:InitialContactPhase",
      "rdfs:label": "Embassy Residence Trust Access",
      "rdfs:comment": "Mara gained access to MV1 and MV2 through prior U.S. envoy Nancy Flores' established relationship — victims had received food and safety at government Residence 640, Ouagadougou (sentencing memorandum; PSR ¶9)",
      "cac-core:precedes": {"@id": "caselinker:doj_ceos_2026_003-phase-dependency-grooming"}
    },
    {
      "@id": "caselinker:doj_ceos_2026_003-phase-dependency-grooming",
      "@type": "cac-grooming:TrustBuildingPhase",
      "rdfs:label": "Poverty & Maternal-Illness Dependency Grooming",
      "rdfs:comment": "Mara mirrored prior envoy support to create dependence on Residence 640, then leveraged victims' mother's life-threatening illness to demand sex before providing help (sentencing memorandum; PSR ¶¶10-12)",
      "cac-core:precedes": {"@id": "caselinker:doj_ceos_2026_003-phase-physical-escalation"}
    },
    {
      "@id": "caselinker:doj_ceos_2026_003-phase-physical-escalation",
      "@type": "cac-grooming:SexualizationPhase",
      "rdfs:label": "Second-Contact Physical Escalation",
      "rdfs:comment": "Mara groped victims' breasts on second contact and escalated to pinning and violent assaults when his wife was away at work (sentencing memorandum; PSR ¶¶10, 26-29)",
      "cac-core:precedes": {"@id": "caselinker:doj_ceos_2026_003-phase-hands-on-assaults"}
    },
    {
      "@id": "caselinker:doj_ceos_2026_003-phase-hands-on-assaults",
      "@type": "cac-grooming:ExploitationPhase",
      "rdfs:label": "Repeated Residence 640 Assaults",
      "rdfs:comment": "Many months of repeated violent aggravated sexual abuse of MV1 and MV2 inside gated U.S. government residence — judgment counts 1, 2, 4, 6 (Feb–Oct 2023 offense dates)",
      "cac-core:precedes": {"@id": "caselinker:doj_ceos_2026_003-phase-whatsapp-control"}
    },
    {
      "@id": "caselinker:doj_ceos_2026_003-phase-whatsapp-control",
      "@type": "cac-grooming:MaintenancePhase",
      "rdfs:label": "WhatsApp Subservience & Device Control",
      "rdfs:comment": "Mara provided phones and social accounts but retained passwords; sent subservience demands on WhatsApp including image solicitations — count 3 §2422(b) offense date Dec 12, 2023; obstruction when investigated (PSR ¶¶16-22; Gov't Trial Ex. 107; count 7)",
      "cac-core:precedes": {"@id": "caselinker:doj_ceos_2026_003-phase-terminal"}
    },
    {
      "@id": "caselinker:doj_ceos_2026_003-phase-terminal",
      "@type": "cac-grooming:ExploitationPhase",
      "rdfs:label": "Extraterritorial Minor Victim Harm",
      "rdfs:comment": "Terminal state — embassy power asymmetry sustained hands-on abuse of two impoverished minor victims until U.S. investigation; life imprisonment (judgment Doc 157)",
      "caselinker:is_terminal": true
    },
