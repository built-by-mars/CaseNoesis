  "@graph": [
    {
      "@id": "caselinker:doj_ceos_2026_007-investigation",
      "@type": "cacontology:CACInvestigation",
      "rdfs:label": "United States v. Parker · M.D. Ala. 3:25-cr-00214 · 18 U.S.C. § 2251(d)",
      "cacontology:hasStep": [
        {"@id": "caselinker:doj_ceos_2026_007-phase-forum-membership"},
        {"@id": "caselinker:doj_ceos_2026_007-phase-promotion-posting"},
        {"@id": "caselinker:doj_ceos_2026_007-phase-moderator-staff"},
        {"@id": "caselinker:doj_ceos_2026_007-phase-staff-migration"},
        {"@id": "caselinker:doj_ceos_2026_007-phase-link-advertising"},
        {"@id": "caselinker:doj_ceos_2026_007-phase-moderator-maintenance"},
        {"@id": "caselinker:doj_ceos_2026_007-phase-terminal"}
      ]
    },
    {
      "@id": "caselinker:doj_ceos_2026_007-phase-forum-membership",
      "@type": "cac-grooming:InitialContactPhase",
      "rdfs:label": "Subject Website Membership",
      "rdfs:comment": "July 2023 — defendant joined Subject Website dark-web forum with many thousands of registered members and topic subforums devoted to child pornography (plea agreement factual basis ¶29(a))",
      "cac-core:precedes": {"@id": "caselinker:doj_ceos_2026_007-phase-promotion-posting"}
    },
    {
      "@id": "caselinker:doj_ceos_2026_007-phase-promotion-posting",
      "@type": "cac-grooming:InitialContactPhase",
      "rdfs:label": "CP Contribution Promotion Ladder",
      "rdfs:comment": "July 2023 through September 2024 — defendant made 500+ posts with download links and preview images to establish and maintain site status; staff chosen based on CP contributions (plea agreement ¶29(a)-(b))",
      "cac-core:precedes": {"@id": "caselinker:doj_ceos_2026_007-phase-moderator-staff"}
    },
    {
      "@id": "caselinker:doj_ceos_2026_007-phase-moderator-staff",
      "@type": "cac-grooming:TrustBuildingPhase",
      "rdfs:label": "Moderator Staff Operations",
      "rdfs:comment": "Defendant served as one of ~20 staff moderators policing user posts for compliance with Subject Website rules requiring under-18 depictions and link-plus-preview format (plea agreement ¶29(a),(d))",
      "cac-core:precedes": {"@id": "caselinker:doj_ceos_2026_007-phase-staff-migration"}
    },
    {
      "@id": "caselinker:doj_ceos_2026_007-phase-staff-migration",
      "@type": "cac-platforms:ChannelMigrationEvent",
      "rdfs:label": "Contributor → Moderator Staff Migration",
      "rdfs:comment": "High-volume CP posting elevated defendant into moderator staff channel with rule-enforcement authority over other users (plea agreement ¶29(b),(d))",
      "cac-platforms:fromPlatform": "Subject Website member forums",
      "cac-platforms:toPlatform": "Subject Website moderator staff operations",
      "cac-platforms:migrationRationale": "capability_upgrade",
      "cac-platforms:occursBetween": [
        {"@id": "caselinker:doj_ceos_2026_007-phase-moderator-staff"},
        {"@id": "caselinker:doj_ceos_2026_007-phase-link-advertising"}
      ],
      "cac-core:precedes": {"@id": "caselinker:doj_ceos_2026_007-phase-link-advertising"}
    },
    {
      "@id": "caselinker:doj_ceos_2026_007-phase-link-advertising",
      "@type": "cac-grooming:ExploitationPhase",
      "rdfs:label": "Link-and-Preview CP Advertising",
      "rdfs:comment": "September 2023, January 2024, and June 2024 example posts knowingly published notices and advertisements offering to distribute child pornography via interstate internet links and preview images (plea agreement ¶29(b)-(c); Count 1)",
      "cac-core:precedes": {"@id": "caselinker:doj_ceos_2026_007-phase-moderator-maintenance"}
    },
    {
      "@id": "caselinker:doj_ceos_2026_007-phase-moderator-maintenance",
      "@type": "cac-grooming:MaintenancePhase",
      "rdfs:label": "Sustained Moderator Enforcement",
      "rdfs:comment": "Through September 2024 — defendant continued moderator duties and CP posting, including noting posting limits imposed by staff responsibilities (plea agreement ¶29(d))",
      "cac-core:precedes": {"@id": "caselinker:doj_ceos_2026_007-phase-terminal"}
    },
    {
      "@id": "caselinker:doj_ceos_2026_007-phase-terminal",
      "@type": "cac-grooming:ExploitationPhase",
      "rdfs:label": "Distributed Subject Website Archive",
      "rdfs:comment": "Terminal state — February 2025 FBI search in Lee County, Alabama seized thousands of CSAM images and videos; Subject Website distributed copies persist beyond single-device seizure (plea agreement ¶29(e); 292-month sentence)",
      "caselinker:is_terminal": true
    },
    {
      "@id": "caselinker:doj_ceos_2026_007-affordance-membership-promotion",
      "@type": "cac-platforms:AffordanceMisuse",
      "cac-platforms:enablesTransitionFrom": {"@id": "caselinker:doj_ceos_2026_007-phase-forum-membership"},
      "cac-platforms:enablesTransitionTo": {"@id": "caselinker:doj_ceos_2026_007-phase-promotion-posting"},
      "cac-platforms:affordanceClass": {"@id": "cac-platforms:ContactDiscovery"},
      "cac-platforms:misuseDescription": "Open forum registration lowers barrier; CP sharing unlocks staff consideration"
    },
    {
      "@id": "caselinker:doj_ceos_2026_007-affordance-promotion-staff",
      "@type": "cac-platforms:AffordanceMisuse",
      "cac-platforms:enablesTransitionFrom": {"@id": "caselinker:doj_ceos_2026_007-phase-promotion-posting"},
      "cac-platforms:enablesTransitionTo": {"@id": "caselinker:doj_ceos_2026_007-phase-moderator-staff"},
      "cac-platforms:affordanceClass": {"@id": "cac-platforms:Coordination"},
      "cac-platforms:misuseDescription": "Sustained CP contributions earn moderator staff authority among ~20 operators"
    },
    {
      "@id": "caselinker:doj_ceos_2026_007-affordance-staff-migration",
      "@type": "cac-platforms:AffordanceMisuse",
      "cac-platforms:enablesTransitionFrom": {"@id": "caselinker:doj_ceos_2026_007-phase-moderator-staff"},
      "cac-platforms:enablesTransitionTo": {"@id": "caselinker:doj_ceos_2026_007-phase-staff-migration"},
      "cac-platforms:affordanceClass": {"@id": "cac-platforms:Coordination"},
      "cac-platforms:misuseDescription": "Staff role migrates defendant from contributor to rule-enforcement operator"
    },
    {
      "@id": "caselinker:doj_ceos_2026_007-affordance-migration-advertising",
      "@type": "cac-platforms:AffordanceMisuse",
      "cac-platforms:enablesTransitionFrom": {"@id": "caselinker:doj_ceos_2026_007-phase-staff-migration"},
      "cac-platforms:enablesTransitionTo": {"@id": "caselinker:doj_ceos_2026_007-phase-link-advertising"},
      "cac-platforms:affordanceClass": {"@id": "cac-platforms:DistributionInfrastructure"},
      "cac-platforms:misuseDescription": "Site rules channel link-plus-preview posts to external download hosts"
    },
    {
      "@id": "caselinker:doj_ceos_2026_007-affordance-advertising-maintenance",
      "@type": "cac-platforms:AffordanceMisuse",
      "cac-platforms:enablesTransitionFrom": {"@id": "caselinker:doj_ceos_2026_007-phase-link-advertising"},
      "cac-platforms:enablesTransitionTo": {"@id": "caselinker:doj_ceos_2026_007-phase-moderator-maintenance"},
      "cac-platforms:affordanceClass": {"@id": "cac-platforms:DistributionInfrastructure"},
      "cac-platforms:misuseDescription": "Moderator enforcement sustains on-topic CP repositories across subforums"
    },
    {
      "@id": "caselinker:doj_ceos_2026_007-affordance-maintenance-terminal",
      "@type": "cac-platforms:AffordanceMisuse",
