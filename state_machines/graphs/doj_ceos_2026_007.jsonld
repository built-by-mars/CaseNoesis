      "cac-platforms:enablesTransitionTo": {"@id": "caselinker:doj_ceos_2026_007-phase-terminal"},
      "cac-platforms:affordanceClass": {"@id": "cac-platforms:DistributionInfrastructure"},
      "cac-platforms:misuseDescription": "Distributed Subject Website copies and seized device archives — no single seizure recovers all material"
