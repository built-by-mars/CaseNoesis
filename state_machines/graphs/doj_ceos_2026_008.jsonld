      "@type": "cac-grooming:SexualizationPhase",
      "rdfs:label": "Victim 1 Directed Production",
      "rdfs:comment": "November 26, 2021 — Victim 1 sent 15-second self-produced video at defendant direction via Facebook (stipulation of facts; indictment Count 1)",
      "cac-core:precedes": {
        "@id": "caselinker:doj_ceos_2026_008-phase-paid-solicitation"
      }
