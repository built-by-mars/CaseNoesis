        "cac-core:Phase"
      ],
      "rdfs:label": "Paid Commissioning & Scripted Requests",
      "rdfs:comment": "Defendant enticed Victim 1 to perform sexual acts on camera in exchange for money; sent money-transfer ID numbers and negotiated video specifications before depictions were transmitted (stipulation of facts)",
      "cac-core:precedes": {
        "@id": "caselinker:doj_ceos_2026_008-phase-directed-production"
