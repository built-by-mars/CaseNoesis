      "rdfs:comment": "CS:GO, Roblox; in-game chat; pseudonymous gaming identities. Enterprise role: Recruiters",
      "cac-core:precedes": {
        "@id": "caselinker:bermudez-phase-enterprise-recruitment"
      }
    },
    {
      "@id": "caselinker:bermudez-phase-enterprise-recruitment",
      "@type": "cac-grooming:InitialContactPhase",
      "rdfs:label": "Enterprise Recruitment",
      "rdfs:comment": "Discord invite; role assignment; victims recruited by coerced existing victims. Enterprise role: Coordinators",
      "cac-core:precedes": {
        "@id": "caselinker:bermudez-phase-parallel-grooming"
      }
    },
    {
