      "cac-platforms:fromPlatform": "CS:GO / Roblox",
      "cac-platforms:toPlatform": "Discord",
      "cac-platforms:migrationRationale": "capability_upgrade",
      "cac-platforms:occursBetween": [
        {
          "@id": "caselinker:bermudez-phase-parallel-grooming"
        },
        {
          "@id": "caselinker:bermudez-phase-parallel-production"
