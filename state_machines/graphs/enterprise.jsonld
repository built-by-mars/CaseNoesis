      "@id": "caselinker:bermudez-phase-parallel-production",
      "@type": "cac-grooming:ExploitationPhase",
      "rdfs:label": "Parallel Directed Production",
      "rdfs:comment": "Coordinators direct producers; producers direct victims; simultaneous across multiple victims. Enterprise role: Producers",
      "cac-core:precedes": {
        "@id": "caselinker:bermudez-phase-gated-distribution"
      }
    },
