    {
      "@id": "caselinker:rehman-phase-initial-contact",
      "@type": "cac-grooming:InitialContactPhase",
      "rdfs:label": "Platform Contact",
      "rdfs:comment": "Single platform, pseudonymous approach",
      "cac-core:precedes": {
        "@id": "caselinker:rehman-phase-trust-building"
      }
    },
    {
      "@id": "caselinker:rehman-phase-trust-building",
      "@type": [
        "cac-grooming:ConditioningPhase",
        "cac-core:Phase"
      ],
      "rdfs:label": "Normalization & Trust",
      "rdfs:comment": "Flattery to disclosed vulnerability, reciprocal disclosure, normalization of sexual content",
      "cac-core:precedes": {
        "@id": "caselinker:rehman-phase-sexualization"
      },
      "cac-core:conditioningMode": "normalization"
    },
    {
      "@id": "caselinker:rehman-phase-sexualization",
      "@type": "cac-grooming:SexualizationPhase",
      "rdfs:label": "First Compliance",
      "rdfs:comment": "First explicit request fulfilled; prior normalization made refusal psychologically costly",
      "cac-core:precedes": {
        "@id": "caselinker:rehman-phase-exploitation"
      }
    },
    {
      "@id": "caselinker:rehman-phase-exploitation",
      "@type": "cac-grooming:ExploitationPhase",
      "rdfs:label": "Escalating Solicitation",
      "rdfs:comment": "Directed production, CSAM produced as escalation instrument not coercion endpoint",
      "cac-core:precedes": {
        "@id": "caselinker:rehman-phase-maintenance"
      }
    },
    {
      "@id": "caselinker:rehman-phase-maintenance",
      "@type": "cac-grooming:MaintenancePhase",
      "rdfs:label": "Material Retained",
      "rdfs:comment": "CSAM held as record of escalation",
      "cac-core:precedes": {
        "@id": "caselinker:rehman-phase-terminal"
      }
    },
    {
      "@id": "caselinker:rehman-phase-terminal",
      "@type": "cac-grooming:ExploitationPhase",
      "rdfs:label": "Meeting → Physical Contact",
      "rdfs:comment": "Terminal state — offense progresses to physical terminus; does not cycle"
    },
