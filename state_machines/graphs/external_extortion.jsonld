  "@graph": [
    {
      "@id": "caselinker:external_extortion-investigation",
      "@type": "cacontology:CACInvestigation",
      "rdfs:label": "United States v. Murphy · D. Mass. 1:19-cr-10286 · 18 U.S.C. § 2251(a)",
      "cacontology:hasStep": [
        {
          "@id": "caselinker:external_extortion-phase-persona-contact"
        },
        {
          "@id": "caselinker:external_extortion-phase-teen-girl-deception"
        },
        {
          "@id": "caselinker:external_extortion-phase-first-production"
        },
        {
          "@id": "caselinker:external_extortion-phase-exposure-threats"
        },
        {
          "@id": "caselinker:external_extortion-phase-degradation-demands"
        },
        {
          "@id": "caselinker:external_extortion-phase-coercion-cycle"
        },
        {
          "@id": "caselinker:external_extortion-phase-device-archive"
        },
        {
          "@id": "caselinker:external_extortion-phase-terminal"
        }
      ]
    },
    {
      "@id": "caselinker:external_extortion-phase-persona-contact",
      "@type": "cac-grooming:InitialContactPhase",
      "rdfs:label": "Multi-Persona Snapchat Contact",
      "rdfs:comment": "June 2017 through March 2019 — defendant contacted minor boys using fake teenage girl personas across Snapchat and Snap Hat accounts including sarah.shayl, mikala-shaw, emilyhunter.l6, mattyc.1234, and lastchaneb4-911 (indictment Counts 1–5)",
      "cac-core:precedes": {
        "@id": "caselinker:external_extortion-phase-teen-girl-deception"
      }
    },
    {
      "@id": "caselinker:external_extortion-phase-teen-girl-deception",
      "@type": [
        "cac-grooming:ConditioningPhase",
        "cac-core:Phase"
      ],
      "rdfs:label": "Teenage Girl Catfish Grooming",
      "rdfs:comment": "Defendant pretended to be a teenage girl and persuaded boys to send nude photographs, building leverage for later coercion (sentencing memorandum; PSR ¶¶10–12)",
      "cac-core:precedes": {
        "@id": "caselinker:external_extortion-phase-first-production"
      },
      "cac-core:conditioningMode": "deception"
    },
    {
      "@id": "caselinker:external_extortion-phase-first-production",
      "@type": "cac-grooming:ExploitationPhase",
      "rdfs:label": "First CSAM Production & Leverage",
      "rdfs:comment": "Initial sexually explicit depictions produced and transmitted interstate via Snapchat personas; asymmetry created before exposure threats escalated (indictment Counts 1–5; judgment)",
      "cac-core:precedes": {
        "@id": "caselinker:external_extortion-phase-exposure-threats"
      }
    },
    {
      "@id": "caselinker:external_extortion-phase-exposure-threats",
      "@type": "cac-sextortion:ThreatMechanism",
      "rdfs:label": "Threat to Expose",
      "rdfs:comment": "Defendant threatened to expose victims to friends, family, school, and police; backed threats by sending victims pictures of themselves or other minors (sentencing memorandum; PSR ¶¶18–21)",
      "cac-core:precedes": {
        "@id": "caselinker:external_extortion-phase-degradation-demands"
      }
    },
    {
      "@id": "caselinker:external_extortion-phase-degradation-demands",
      "@type": "cac-grooming:SexualizationPhase",
      "rdfs:label": "Escalating Degradation Demands",
      "rdfs:comment": "Under exposure leverage, defendant demanded additional explicit imagery and commanded humiliation, self-harm, and degrading conduct from victims (sentencing memorandum; PSR ¶¶18–19, 21)",
      "cac-core:precedes": {
        "@id": "caselinker:external_extortion-phase-coercion-cycle"
      }
    },
    {
      "@id": "caselinker:external_extortion-phase-coercion-cycle",
      "@type": "cac-sextortion:CoercionCycle",
      "rdfs:label": "Serial Extortion & Account Takeover",
      "rdfs:comment": "Continued coercion for more imagery; defendant extorted access to victims' Snapchat accounts to contact additional minors; distributed depictions to at least one third-party user (sentencing memorandum; PSR ¶¶18, 21)",
      "cac-core:precedes": {
        "@id": "caselinker:external_extortion-phase-device-archive"
      }
    },
    {
      "@id": "caselinker:external_extortion-phase-device-archive",
      "@type": "cac-grooming:MaintenancePhase",
      "rdfs:label": "Multi-Device CSAM Archive",
      "rdfs:comment": "Laptops, iPads, and iPhone subject to § 2253 forfeiture sustained retained depictions across 15+ identified victims and hundreds of additional contacts (indictment forfeiture allegation; sentencing memorandum)",
      "cac-core:precedes": {
        "@id": "caselinker:external_extortion-phase-terminal"
      }
    },
    {
      "@id": "caselinker:external_extortion-phase-terminal",
      "@type": "cac-grooming:ExploitationPhase",
      "rdfs:label": "Serial Multi-Victim Harm",
      "rdfs:comment": "Terminal state — investigation exposed only after Minor A came forward; Boy Scout leader trust breach; 396-month sentence on five production counts (judgment Doc 58)",
      "caselinker:is_terminal": true
    },
    {
