  "@graph": [
    {
      "@id": "caselinker:gastelo-investigation",
      "@type": "cacontology:CACInvestigation",
      "rdfs:label": "United States v. Gastelo · E.D. Cal. 1:20-cr-00252 · 18 U.S.C. §§ 2251, 2252",
      "cacontology:hasStep": [
        {"@id": "caselinker:gastelo-phase-catfish-contact"},
        {"@id": "caselinker:gastelo-phase-cp-group-access"},
        {"@id": "caselinker:gastelo-phase-encrypted-migration"},
        {"@id": "caselinker:gastelo-phase-omegle-funnel"},
        {"@id": "caselinker:gastelo-phase-directed-production"},
        {"@id": "caselinker:gastelo-phase-archive"},
        {"@id": "caselinker:gastelo-phase-terminal"}
      ]
    },
    {
      "@id": "caselinker:gastelo-phase-catfish-contact",
      "@type": "cac-grooming:InitialContactPhase",
      "rdfs:label": "Grindr Catfish Contact",
      "rdfs:comment": "Posed as 18-year-old; solicited explicit images from purported minors on dating app",
      "cac-core:precedes": {"@id": "caselinker:gastelo-phase-cp-group-access"}
    },
    {
      "@id": "caselinker:gastelo-phase-cp-group-access",
      "@type": "cac-grooming:TrustBuildingPhase",
      "rdfs:label": "CP Group Participation",
      "rdfs:comment": "WhatsApp CP group membership; normalized exchange of child sexual abuse material",
      "cac-core:precedes": {"@id": "caselinker:gastelo-phase-encrypted-migration"}
    },
    {
      "@id": "caselinker:gastelo-phase-encrypted-migration",
      "@type": "cac-platforms:ChannelMigrationEvent",
      "rdfs:label": "Migration to Encrypted Stack",
      "rdfs:comment": "Wickr, Snapchat, Telegram under shared handle; evasion and distribution infrastructure",
      "cac-platforms:fromPlatform": "WhatsApp",
      "cac-platforms:toPlatform": "Wickr / Snapchat / Telegram",
      "cac-platforms:migrationRationale": "evasion_and_capability_upgrade",
      "cac-platforms:occursBetween": [
        {"@id": "caselinker:gastelo-phase-cp-group-access"},
        {"@id": "caselinker:gastelo-phase-omegle-funnel"}
      ],
      "cac-core:precedes": {"@id": "caselinker:gastelo-phase-omegle-funnel"}
    },
    {
      "@id": "caselinker:gastelo-phase-omegle-funnel",
      "@type": "cac-grooming:InitialContactPhase",
      "rdfs:label": "Omegle → Kik → Snapchat Funnel",
      "rdfs:comment": "Live-stream discovery; username exchange; persistent Snapchat contact with MV1",
      "cac-core:precedes": {"@id": "caselinker:gastelo-phase-directed-production"}
    },
    {
      "@id": "caselinker:gastelo-phase-directed-production",
      "@type": "cac-grooming:ExploitationPhase",
      "rdfs:label": "Snapchat Directed Production",
      "rdfs:comment": "Knew victim age 12-13; insisted until explicit images produced; corroborated by device artifacts",
      "cac-core:precedes": {"@id": "caselinker:gastelo-phase-archive"}
    },
    {
      "@id": "caselinker:gastelo-phase-archive",
      "@type": "cac-grooming:MaintenancePhase",
      "rdfs:label": "Device CP Archive",
      "rdfs:comment": "1800+ images and 800+ videos across two Samsung devices; receipt and distribution counts",
      "cac-core:precedes": {"@id": "caselinker:gastelo-phase-terminal"}
    },
    {
      "@id": "caselinker:gastelo-phase-terminal",
      "@type": "cac-grooming:ExploitationPhase",
      "rdfs:label": "Persistent CSAM Archive",
      "rdfs:comment": "Terminal state — production + receipt/distribution plea; 480-month custody; forfeiture ordered"
    },
    {
      "@id": "caselinker:gastelo-affordance-catfish-trust",
      "@type": "cac-platforms:AffordanceMisuse",
      "cac-platforms:enablesTransitionFrom": {"@id": "caselinker:gastelo-phase-catfish-contact"},
      "cac-platforms:enablesTransitionTo": {"@id": "caselinker:gastelo-phase-cp-group-access"},
      "cac-platforms:affordanceClass": {"@id": "cac-platforms:Anonymity"},
      "cac-platforms:misuseDescription": "Age misrepresentation on Grindr lowers victim guard before group exposure"
    },
    {
      "@id": "caselinker:gastelo-affordance-trust-migration",
      "@type": "cac-platforms:AffordanceMisuse",
      "cac-platforms:enablesTransitionFrom": {"@id": "caselinker:gastelo-phase-cp-group-access"},
      "cac-platforms:enablesTransitionTo": {"@id": "caselinker:gastelo-phase-encrypted-migration"},
      "cac-platforms:affordanceClass": {"@id": "cac-platforms:DistributionInfrastructure"},
      "cac-platforms:misuseDescription": "Group CP normalization precedes move to E2E apps"
    },
    {
      "@id": "caselinker:gastelo-affordance-migration-funnel",
      "@type": "cac-platforms:AffordanceMisuse",
      "cac-platforms:enablesTransitionFrom": {"@id": "caselinker:gastelo-phase-encrypted-migration"},
      "cac-platforms:enablesTransitionTo": {"@id": "caselinker:gastelo-phase-omegle-funnel"},
      "cac-platforms:affordanceClass": {"@id": "cac-platforms:ContactDiscovery"},
      "cac-platforms:misuseDescription": "Encrypted handles bridge group trading to live victim discovery on Omegle"
    },
    {
      "@id": "caselinker:gastelo-affordance-funnel-production",
      "@type": "cac-platforms:AffordanceMisuse",
      "cac-platforms:enablesTransitionFrom": {"@id": "caselinker:gastelo-phase-omegle-funnel"},
      "cac-platforms:enablesTransitionTo": {"@id": "caselinker:gastelo-phase-directed-production"},
      "cac-platforms:affordanceClass": {"@id": "cac-platforms:UnmonitoredCommunication"},
      "cac-platforms:misuseDescription": "Ephemeral Snapchat + cross-app funnel enables directed production"
    },
    {
      "@id": "caselinker:gastelo-affordance-production-archive",
      "@type": "cac-platforms:AffordanceMisuse",
      "cac-platforms:enablesTransitionFrom": {"@id": "caselinker:gastelo-phase-directed-production"},
      "cac-platforms:enablesTransitionTo": {"@id": "caselinker:gastelo-phase-archive"},
      "cac-platforms:affordanceClass": {"@id": "cac-platforms:DistributionInfrastructure"},
      "cac-platforms:misuseDescription": "Produced and traded material archived on seized mobile devices"
    },
    {
      "@id": "caselinker:gastelo-affordance-archive-terminal",
      "@type": "cac-platforms:AffordanceMisuse",
      "cac-platforms:enablesTransitionFrom": {"@id": "caselinker:gastelo-phase-archive"},
      "cac-platforms:enablesTransitionTo": {"@id": "caselinker:gastelo-phase-terminal"},
      "cac-platforms:affordanceClass": {"@id": "cac-platforms:DistributionInfrastructure"},
      "cac-platforms:misuseDescription": "Large local archive sustains harm and supports receipt/distribution charges"
    }
  ]
