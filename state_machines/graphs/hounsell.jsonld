    {
      "@id": "caselinker:hounsell-phase-cross-border-contact",
      "@type": "cac-grooming:InitialContactPhase",
      "rdfs:label": "Cross-Border Social Media Contact",
      "rdfs:comment": "Wisconsin defendant to Philippines facilitator via social media; interstate and foreign commerce element",
      "cac-core:precedes": {"@id": "caselinker:hounsell-phase-facilitator-grooming"}
    },
    {
      "@id": "caselinker:hounsell-phase-facilitator-grooming",
      "@type": "cac-grooming:TrustBuildingPhase",
      "rdfs:label": "Facilitator Grooming & Payment Negotiation",
      "rdfs:comment": "Sexual preference questions, pose instructions, money offers to induce minor compliance via third party",
      "cac-core:precedes": {"@id": "caselinker:hounsell-phase-paid-production"}
    },
    {
      "@id": "caselinker:hounsell-phase-paid-production",
      "@type": "cac-grooming:ExploitationPhase",
      "rdfs:label": "Third-Party Paid Production",
      "rdfs:comment": "Facilitator produces video at defendant request after money transfer; victim abroad, defendant domestic",
      "cac-core:precedes": {"@id": "caselinker:hounsell-phase-material-retention"}
    },
    {
      "@id": "caselinker:hounsell-phase-material-retention",
      "@type": "cac-grooming:MaintenancePhase",
      "rdfs:label": "Material Retained & Repeat Solicitation",
      "rdfs:comment": "Video recovered from facilitator account and defendant phone; additional paid image/video requests documented",
      "cac-core:precedes": {"@id": "caselinker:hounsell-phase-terminal"}
    },
    {
      "@id": "caselinker:hounsell-phase-terminal",
      "@type": "cac-grooming:ExploitationPhase",
      "rdfs:label": "Federal Conviction — Enticement",
      "rdfs:comment": "Terminal state — 2422(b) plea; original 2251 production count dismissed; 156-month sentence"
    },
    {
      "@id": "caselinker:hounsell-affordance-contact-grooming",
      "@type": "cac-platforms:AffordanceMisuse",
      "cac-platforms:enablesTransitionFrom": {"@id": "caselinker:hounsell-phase-cross-border-contact"},
      "cac-platforms:enablesTransitionTo": {"@id": "caselinker:hounsell-phase-facilitator-grooming"},
      "cac-platforms:affordanceClass": {"@id": "cac-platforms:UnmonitoredCommunication"},
      "cac-platforms:misuseDescription": "Cross-border DM enables grooming without parental visibility"
    },
    {
      "@id": "caselinker:hounsell-affordance-grooming-production",
      "@type": "cac-platforms:AffordanceMisuse",
      "cac-platforms:enablesTransitionFrom": {"@id": "caselinker:hounsell-phase-facilitator-grooming"},
      "cac-platforms:enablesTransitionTo": {"@id": "caselinker:hounsell-phase-paid-production"},
      "cac-platforms:affordanceClass": {"@id": "cac-platforms:CoercionLeverage"},
      "cac-platforms:misuseDescription": "Payment transfer converts grooming requests into produced CSAM via facilitator"
    },
    {
      "@id": "caselinker:hounsell-affordance-production-retention",
