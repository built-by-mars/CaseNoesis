      "rdfs:label": "Multi-Device CSAM Archive",
      "rdfs:comment": "KSP seized UMX, Maxwest, Motorola Moto E6, Lenovo Chromebook, and Moto E6 devices from Stafford; judgment orders forfeiture of all listed electronics",
      "cac-core:precedes": {"@id": "caselinker:ky_sp_2025_038-phase-terminal"}
    },
