    {
      "@id": "caselinker:ky_sp_2025_038-phase-craig-wright-lure",
      "@type": "cac-grooming:InitialContactPhase",
      "rdfs:label": "Craig Wright Catfish Romance",
      "rdfs:comment": "Stafford used fake Facebook Messenger persona Craig Wright to lure Victim E into an online romance; KSP investigation opened after parent complaint of group chat containing victim nudes",
      "cac-core:precedes": {"@id": "caselinker:ky_sp_2025_038-phase-intimate-harvesting"}
    },
    {
      "@id": "caselinker:ky_sp_2025_038-phase-intimate-harvesting",
      "@type": "cac-grooming:TrustBuildingPhase",
      "rdfs:label": "Intimate Harvesting & Contract Fiction",
      "rdfs:comment": "Through Craig Wright, Stafford obtained intimate details and visual depictions; introduced fake illegal 'company' contract fiction that victim believed bound her to comply",
      "cac-core:precedes": {"@id": "caselinker:ky_sp_2025_038-phase-sextortion-escalation"}
    },
    {
      "@id": "caselinker:ky_sp_2025_038-phase-sextortion-escalation",
      "@type": "cac-grooming:SexualizationPhase",
      "rdfs:label": "Multi-Persona Sextortion Demands",
      "rdfs:comment": "RexRiddle Hado and Zeke Carter personas used harvested material to extort Victim E for additional explicit imagery and compliance; family-harm threats if victim refused",
      "cac-core:precedes": {"@id": "caselinker:ky_sp_2025_038-phase-campbell-recruitment"}
    },
    {
      "@id": "caselinker:ky_sp_2025_038-phase-campbell-recruitment",
      "@type": "cac-grooming:TrustBuildingPhase",
      "rdfs:label": "Campbell Third-Party Coercion Funnel",
      "rdfs:comment": "Stafford ran parallel fake-persona thread grooming co-offender Campbell with phony love interest Meghan; RexRiddle Hado demanded Campbell film sex with Victim E or pay $200 gift card",
      "cac-core:precedes": {"@id": "caselinker:ky_sp_2025_038-phase-directed-production"}
    },
    {
      "@id": "caselinker:ky_sp_2025_038-phase-directed-production",
      "@type": "cac-grooming:ExploitationPhase",
      "rdfs:label": "June 10 Garage Directed Production",
      "rdfs:comment": "Campbell traveled to Victim E's Anderson County home; victim disclosed coercion; Campbell filmed vaginal intercourse creating the June 10th video series on his phone",
      "cac-core:precedes": {"@id": "caselinker:ky_sp_2025_038-phase-series-transmission"}
    },
    {
      "@id": "caselinker:ky_sp_2025_038-phase-series-transmission",
      "@type": "cac-grooming:ExploitationPhase",
      "rdfs:label": "June 10th Series Transmission",
      "rdfs:comment": "Campbell sent sexually explicit videos to RexRiddle Hado via Facebook Messenger; Stafford admits he controlled all fake personas and orchestrated production using interstate internet and out-of-state devices",
      "cac-core:precedes": {"@id": "caselinker:ky_sp_2025_038-phase-device-archive"}
    },
    {
      "@id": "caselinker:ky_sp_2025_038-phase-device-archive",
