      "@type": "cac-grooming:InitialContactPhase",
      "rdfs:label": "Online Dating App Contact",
      "rdfs:comment": "2019 — defendant connected with 14-year-old Minor 2 through online dating application (sentencing memorandum PSR ¶29; plea stipulated exploitation Section B)",
      "cac-core:precedes": {"@id": "caselinker:ncis_2022_002-phase-jeff-grooming"}
    },
    {
      "@id": "caselinker:ncis_2022_002-phase-jeff-grooming",
      "@type": "cac-grooming:TrustBuildingPhase",
      "rdfs:label": "Jeff Persona & Persistent Solicitation",
      "rdfs:comment": "Defendant posed as Jeff/jeffg2007; voice and video calls on Application A; daily explicit photo requests even when Minor 2 at school (sentencing memorandum PSR ¶¶29, Section B)",
      "cac-core:precedes": {"@id": "caselinker:ncis_2022_002-phase-minor1-enticement"}
    },
    {
      "@id": "caselinker:ncis_2022_002-phase-minor1-enticement",
      "@type": "cac-grooming:ExploitationPhase",
      "rdfs:label": "Minor 1 Five-Day Enticement",
      "rdfs:comment": "Nov 7–12, 2021 — defendant misrepresented age as 22 to 12-year-old Minor 1 on Application A; graphic sexual chat, solicited genital image and mutual masturbation (superseding indictment Count 1; sentencing memorandum Section A)",
      "cac-core:precedes": {"@id": "caselinker:ncis_2022_002-phase-minor2-production"}
    },
    {
      "@id": "caselinker:ncis_2022_002-phase-minor2-production",
      "@type": "cac-grooming:SexualizationPhase",
      "rdfs:label": "Minor 2 Directed Production",
      "rdfs:comment": "Feb 2022 — at defendant request Minor 2 created sexually explicit masturbation video sent via Application A; defendant screen-recorded to iPhone 12 mini (sentencing memorandum Section B; plea §5 stipulation)",
      "cac-core:precedes": {"@id": "caselinker:ncis_2022_002-phase-csam-enterprise"}
    },
    {
      "@id": "caselinker:ncis_2022_002-phase-csam-enterprise",
      "@type": "cac-grooming:MaintenancePhase",
      "rdfs:label": "Decade Collection & Application B Trading",
      "rdfs:comment": "~600 CSAM files on laptops including encrypted zip; Application B group trading Aug 2021–Feb 2022; defendant reached Minor 2 again morning of May 18, 2022 search (sentencing memorandum Sections C–D)",
      "cac-core:precedes": {"@id": "caselinker:ncis_2022_002-phase-terminal"}
    },
    {
      "@id": "caselinker:ncis_2022_002-phase-terminal",
      "@type": "cac-grooming:ExploitationPhase",
      "rdfs:label": "Persistent Screen-Recorded Production Archive",
      "rdfs:comment": "Terminal state — screen-recorded Minor 2 production and decade encrypted collection sustain harm to depicted minors (sentencing memorandum; plea forfeiture)",
