    {
      "@id": "caselinker:ncmec_2022_586-phase-snapchat-onset",
      "@type": "cac-grooming:InitialContactPhase",
      "rdfs:label": "darkshadowedday Snapchat Onset",
      "rdfs:comment": "April 6, 2021 — defendant contacted believed-minor Snapchat user via darkshadowedday account, soliciting explicit images (statement of facts ¶10; Jane Doe 2)",
      "cac-core:precedes": {
        "@id": "caselinker:ncmec_2022_586-phase-trust-building"
      }
    },
    {
      "@id": "caselinker:ncmec_2022_586-phase-trust-building",
      "@type": [
        "cac-grooming:ConditioningPhase",
        "cac-core:Phase"
      ],
      "rdfs:label": "darkshadowedday CSAM Trade & Minor Solicitation",
      "rdfs:comment": "On Snapchat account darkshadowedday defendant distributed and received CSAM and solicited nude photographs from users he believed were minors (statement of facts ¶9). He later opened a second account, outcast_misfit, which he used to message Jane Doe 1 and obtain depictions (¶¶16-17) — account rotation, not a separate platform.",
      "cac-core:precedes": {
        "@id": "caselinker:ncmec_2022_586-phase-directed-production"
      },
      "cac-core:conditioningMode": "normalization"
    },
    {
      "@id": "caselinker:ncmec_2022_586-phase-directed-production",
      "@type": "cac-grooming:SexualizationPhase",
      "rdfs:label": "Jane Doe 1 Directed Production",
      "rdfs:comment": "Sept 27, 2021 — defendant solicited explicit conduct from 13-year-old Jane Doe 1 on outcast_misfit; she sent a self-produced video at his direction (statement of facts ¶¶20-21; indictment Count 1)",
      "cac-core:precedes": {
        "@id": "caselinker:ncmec_2022_586-phase-continued-enticement"
      }
    },
    {
      "@id": "caselinker:ncmec_2022_586-phase-continued-enticement",
      "@type": "cac-grooming:ExploitationPhase",
      "rdfs:label": "Continued Snapchat Enticement",
      "rdfs:comment": "Sept 27–Oct 7, 2021 — sustained solicitations for fingering, nudity, and sexual contact with Jane Doe 1 via outcast_misfit (statement of facts ¶¶20, 23; plea Count 2)",
      "cac-core:precedes": {
        "@id": "caselinker:ncmec_2022_586-phase-multi-platform-archive"
      }
    },
    {
      "@id": "caselinker:ncmec_2022_586-phase-multi-platform-archive",
      "@type": "cac-grooming:MaintenancePhase",
      "rdfs:label": "Snapchat / Dropbox / Wickr / Kik Archive",
      "rdfs:comment": "70 images and 23 videos on phone; 62 Snapchat files; 118 Dropbox files in age-sorted folders; Wickr and Kik CSAM exchange (statement of facts ¶¶12-13, 19)",
      "cac-core:precedes": {
        "@id": "caselinker:ncmec_2022_586-phase-terminal"
      }
    },
    {
      "@id": "caselinker:ncmec_2022_586-phase-terminal",
      "@type": "cac-grooming:ExploitationPhase",
      "rdfs:label": "Persistent Multi-Platform CSAM Archive",
      "rdfs:comment": "Terminal state — device- and cloud-retained depictions including Jane Doe 1 production video harm identified victims (statement of facts; 300-month sentence)",
      "caselinker:is_terminal": true
    },
