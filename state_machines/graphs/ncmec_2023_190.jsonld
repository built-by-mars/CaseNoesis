      "@type": "cac-grooming:InitialContactPhase",
      "rdfs:label": "Multi-Persona Snapchat Onset",
      "rdfs:comment": "Sept 14, 2021 — defendant contacted 12-year-old Jane Doe 1 on Snapchat username zanesmjth; nine NCMEC CyberTips tied to multiple linked Snapchat handles Aug–Nov 2021 (statement of facts ¶¶1, 16)",
      "cac-core:precedes": {"@id": "caselinker:ncmec_2023_190-phase-trust-building"}
    },
    {
      "@id": "caselinker:ncmec_2023_190-phase-trust-building",
      "@type": "cac-grooming:TrustBuildingPhase",
      "rdfs:label": "Instructional Grooming & Covert Recording",
      "rdfs:comment": "Defendant instructed victims how to make videos, asked to keep depictions; Mobizen and recording software retained Snapchat interactions unbeknownst to victims (statement of facts ¶¶14-15)",
      "cac-core:precedes": {"@id": "caselinker:ncmec_2023_190-phase-jd1-production"}
    },
    {
      "@id": "caselinker:ncmec_2023_190-phase-jd1-production",
      "@type": "cac-grooming:SexualizationPhase",
      "rdfs:label": "Jane Doe 1 Directed Production",
      "rdfs:comment": "Sept 14, 2021 — after Jane Doe 1 disclosed age 12, defendant instructed sexually explicit conduct; ten-second production video sent on zanesmjth (statement of facts ¶16; Count 1)",
      "cac-core:precedes": {"@id": "caselinker:ncmec_2023_190-phase-multi-victim-production"}
    },
    {
      "@id": "caselinker:ncmec_2023_190-phase-multi-victim-production",
      "@type": "cac-grooming:ExploitationPhase",
      "rdfs:label": "Parallel Victim Production Threads",
      "rdfs:comment": "Sept 15, 2021 Jane Doe 5 image production; Oct 24, 2021 Jane Doe 6 compilation; Nov 27, 2021 Jane Doe 6/7 asleep exploitation; March 13, 2022 Jane Doe 8/9 including toddler-directed conduct (statement of facts ¶¶17-25)",
      "cac-core:precedes": {"@id": "caselinker:ncmec_2023_190-phase-compilation-archive"}
    },
    {
      "@id": "caselinker:ncmec_2023_190-phase-compilation-archive",
      "@type": "cac-grooming:MaintenancePhase",
      "rdfs:label": "Compilation & Mobizen Archive",
      "rdfs:comment": "Defendant created multi-minute compilation videos from Jane Doe 6 threads; Mobizen recordings of Jane Doe 8 interactions stored on twelve seized devices (statement of facts ¶¶20-25)",
      "cac-core:precedes": {"@id": "caselinker:ncmec_2023_190-phase-terminal"}
    },
    {
      "@id": "caselinker:ncmec_2023_190-phase-terminal",
      "@type": "cac-grooming:ExploitationPhase",
      "rdfs:label": "Persistent Multi-Victim Production Archive",
      "rdfs:comment": "Terminal state — covert recordings and defendant-edited compilations sustain harm across six Jane Doe victims (statement of facts; judgment 360 months)",
