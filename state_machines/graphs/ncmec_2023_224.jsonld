      "@id": "caselinker:ncmec_2023_224-phase-kik-onset",
      "@type": "cac-grooming:InitialContactPhase",
      "rdfs:label": "Kik Contact with Minor Victim 1",
      "rdfs:comment": "June 2021 — defendant began communicating with 13-year-old girl on Kik using interstate cellular networks and internet (guilty plea admission; superseding indictment Count 1 anchors attempted enticement on or about June 21, 2022)",
      "cac-core:precedes": {
        "@id": "caselinker:ncmec_2023_224-phase-trust-building"
      }
    },
    {
      "@id": "caselinker:ncmec_2023_224-phase-trust-building",
      "@type": [
        "cac-grooming:ConditioningPhase",
        "cac-core:Phase"
      ],
      "rdfs:label": "False-Age Grooming & Sexual Normalization",
      "rdfs:comment": "Defendant pretended to be 17 years old; sent pornographic images; explained sexual intercourse before asking victim to undress — identity misrepresentation and computer-facilitated grooming (guilty plea; USSG §2G1.3(b)(2) enhancement in sentencing memorandum)",
      "cac-core:precedes": {
        "@id": "caselinker:ncmec_2023_224-phase-video-enticement"
      },
      "cac-core:conditioningMode": "deception"
    },
    {
      "@id": "caselinker:ncmec_2023_224-phase-video-enticement",
      "@type": "cac-grooming:SexualizationPhase",
      "rdfs:label": "Video-Call Enticement & Production Attempt",
      "rdfs:comment": "June 21, 2022 — defendant attempted to persuade, induce, entice, and coerce Minor Victim 1 to engage in sexual activity and sexually explicit conduct for visual depiction; initiated video calls attempting sexual conduct (superseding indictment Counts 1–2; guilty plea)",
      "cac-core:precedes": {
        "@id": "caselinker:ncmec_2023_224-phase-parallel-solicitation"
      }
    },
    {
      "@id": "caselinker:ncmec_2023_224-phase-parallel-solicitation",
      "@type": "cac-grooming:ExploitationPhase",
      "rdfs:label": "Parallel Believed-Minor Solicitation",
      "rdfs:comment": "Defendant engaged in sexual online conversations with multiple individuals he believed were children while posing as a 17-year-old and soliciting sexually explicit images (guilty plea admission)",
      "cac-core:precedes": {
        "@id": "caselinker:ncmec_2023_224-phase-device-archive"
      }
    },
    {
      "@id": "caselinker:ncmec_2023_224-phase-device-archive",
      "@type": "cac-grooming:MaintenancePhase",
      "rdfs:label": "Phone & Kik CSAM Collection",
      "rdfs:comment": "August 1, 2022 — defendant possessed 22 images and 297 videos depicting minors engaging in sexually explicit conduct on cellular phone and Kik account (superseding indictment Count 3; guilty plea admission)",
      "cac-core:precedes": {
        "@id": "caselinker:ncmec_2023_224-phase-terminal"
      }
    },
    {
      "@id": "caselinker:ncmec_2023_224-phase-terminal",
      "@type": "cac-grooming:ExploitationPhase",
      "rdfs:label": "Persistent CSAM Archive Harm",
      "rdfs:comment": "Terminal state — device- and Kik-retained depictions continue to victimize children exploited in production; internet circulation sustains harm beyond defendant's possession (sentencing memorandum)",
      "caselinker:is_terminal": true
    },
