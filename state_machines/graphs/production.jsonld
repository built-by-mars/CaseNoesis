    "ConditioningPhase": "cac-grooming:ConditioningPhase",
    "conditioningMode": "cac-core:conditioningMode"
  },
  "@graph": [
    {
      "@id": "caselinker:pathmanathan-investigation",
      "@type": "cacontology:CACInvestigation",
      "rdfs:label": "United States v. Pathmanathan · D.D.C. 1:22-cr-00150-JEB · 18 U.S.C. § 2251(a),(e)",
      "cacontology:hasStep": [
        {
          "@id": "caselinker:pathmanathan-phase-initial-contact"
        },
        {
          "@id": "caselinker:pathmanathan-phase-trust-building"
        },
        {
          "@id": "caselinker:pathmanathan-phase-migration"
        },
        {
          "@id": "caselinker:pathmanathan-phase-directed-production"
        },
        {
          "@id": "caselinker:pathmanathan-phase-media-capture"
        },
        {
          "@id": "caselinker:pathmanathan-phase-maintenance"
        },
        {
          "@id": "caselinker:pathmanathan-phase-terminal"
        }
      ]
    },
    {
      "@id": "caselinker:pathmanathan-phase-initial-contact",
      "@type": "cac-grooming:InitialContactPhase",
      "rdfs:label": "Visual Profile Targeting",
      "rdfs:comment": "Instagram visual profiles + algorithmic surfacing",
      "cac-core:precedes": {
        "@id": "caselinker:pathmanathan-phase-trust-building"
      }
    },
    {
      "@id": "caselinker:pathmanathan-phase-trust-building",
      "@type": [
        "cac-grooming:ConditioningPhase",
        "cac-core:Phase"
      ],
      "rdfs:label": "DM Coercion",
      "rdfs:comment": "Instagram DM with disappearing messages option",
      "cac-core:precedes": {
        "@id": "caselinker:pathmanathan-phase-migration"
      },
      "cac-core:conditioningMode": "compliance_shaping"
    },
    {
      "@id": "caselinker:pathmanathan-phase-migration",
      "@type": "cac-platforms:ChannelMigrationEvent",
      "rdfs:label": "Migration to Production Channel",
      "rdfs:comment": "Instagram → Messenger; severs evidence trail; accesses live video capability",
      "cac-platforms:fromPlatform": "Instagram",
      "cac-platforms:toPlatform": "Facebook Messenger",
      "cac-platforms:migrationRationale": "capability_upgrade",
      "cac-platforms:occursBetween": [
        {
          "@id": "caselinker:pathmanathan-phase-trust-building"
        },
        {
          "@id": "caselinker:pathmanathan-phase-directed-production"
        }
      ],
      "cac-core:precedes": {
        "@id": "caselinker:pathmanathan-phase-directed-production"
      }
    },
    {
      "@id": "caselinker:pathmanathan-phase-directed-production",
      "@type": "cac-grooming:ExploitationPhase",
      "rdfs:label": "Live Directed Production",
      "rdfs:comment": "Offender commands; victim performs; session recorded including without victim's knowledge",
      "cac-core:precedes": {
        "@id": "caselinker:pathmanathan-phase-media-capture"
      }
    },
    {
      "@id": "caselinker:pathmanathan-phase-media-capture",
      "@type": "cac-grooming:ExploitationPhase",
      "rdfs:label": "Media Capture",
      "rdfs:comment": "Abuse converted to persistent artifact",
      "cac-core:precedes": {
        "@id": "caselinker:pathmanathan-phase-maintenance"
      }
    },
    {
      "@id": "caselinker:pathmanathan-phase-maintenance",
      "@type": "cac-grooming:MaintenancePhase",
      "rdfs:label": "Archive as Ongoing Leverage",
      "rdfs:comment": "Each session adds to archive; harm persists as leverage for future sessions",
      "cac-core:precedes": {
        "@id": "caselinker:pathmanathan-phase-terminal"
      }
    },
    {
      "@id": "caselinker:pathmanathan-phase-terminal",
      "@type": "cac-grooming:ExploitationPhase",
      "rdfs:label": "Persistent CSAM Archive",
      "rdfs:comment": "Harm does not end when contact does"
    },
    {
      "@id": "caselinker:pathmanathan-account-replacement",
      "@type": "cac-grooming:AccountReplacementEvent",
      "rdfs:label": "Victim block account replacement",
      "rdfs:comment": "When victim blocks: offender creates new account and returns to contact. Lifecycle resets, does not terminate.",
      "cac-grooming:triggeredBy": "victim_block",
      "cac-grooming:resumesAt": {
        "@id": "caselinker:pathmanathan-phase-initial-contact"
      }
    },
    {
      "@id": "caselinker:pathmanathan-affordance-initial-trust",
      "@type": "cac-platforms:AffordanceMisuse",
      "cac-platforms:enablesTransitionFrom": {
        "@id": "caselinker:pathmanathan-phase-initial-contact"
      },
      "cac-platforms:enablesTransitionTo": {
        "@id": "caselinker:pathmanathan-phase-trust-building"
      },
      "cac-platforms:affordanceClass": {
        "@id": "cac-platforms:ContactDiscovery"
      },
      "cac-platforms:misuseDescription": "Instagram visual profile + algorithmic surfacing → DM initiation"
    },
    {
      "@id": "caselinker:pathmanathan-affordance-trust-migration",
      "@type": "cac-platforms:AffordanceMisuse",
      "cac-platforms:enablesTransitionFrom": {
        "@id": "caselinker:pathmanathan-phase-trust-building"
      },
      "cac-platforms:enablesTransitionTo": {
        "@id": "caselinker:pathmanathan-phase-migration"
      },
      "cac-platforms:affordanceClass": {
        "@id": "cac-platforms:UnmonitoredCommunication"
      },
      "cac-platforms:misuseDescription": "Contact moves to production-capable channel; evidence trail severed"
    },
    {
      "@id": "caselinker:pathmanathan-affordance-migration-production",
      "@type": "cac-platforms:AffordanceMisuse",
      "cac-platforms:enablesTransitionFrom": {
        "@id": "caselinker:pathmanathan-phase-migration"
      },
      "cac-platforms:enablesTransitionTo": {
        "@id": "caselinker:pathmanathan-phase-directed-production"
      },
      "cac-platforms:affordanceClass": {
        "@id": "cac-platforms:UnmonitoredCommunication"
      },
      "cac-platforms:misuseDescription": "Live video channel enables real-time command of victim's conduct"
    },
    {
      "@id": "caselinker:pathmanathan-affordance-production-capture",
      "@type": "cac-platforms:AffordanceMisuse",
      "cac-platforms:enablesTransitionFrom": {
        "@id": "caselinker:pathmanathan-phase-directed-production"
      },
      "cac-platforms:enablesTransitionTo": {
        "@id": "caselinker:pathmanathan-phase-media-capture"
      },
      "cac-platforms:affordanceClass": {
        "@id": "cac-platforms:UnmonitoredCommunication"
      },
      "cac-platforms:misuseDescription": "Session recorded without victim notification"
    },
    {
      "@id": "caselinker:pathmanathan-affordance-capture-maintenance",
      "@type": "cac-platforms:AffordanceMisuse",
      "cac-platforms:enablesTransitionFrom": {
        "@id": "caselinker:pathmanathan-phase-media-capture"
      },
      "cac-platforms:enablesTransitionTo": {
        "@id": "caselinker:pathmanathan-phase-maintenance"
      },
      "cac-platforms:affordanceClass": {
        "@id": "cac-platforms:DistributionInfrastructure"
      },
      "cac-platforms:misuseDescription": "Device/cloud storage; each session adds to archive"
    },
    {
      "@id": "caselinker:pathmanathan-affordance-maintenance-terminal",
      "@type": "cac-platforms:AffordanceMisuse",
      "cac-platforms:enablesTransitionFrom": {
        "@id": "caselinker:pathmanathan-phase-maintenance"
      },
      "cac-platforms:enablesTransitionTo": {
        "@id": "caselinker:pathmanathan-phase-terminal"
      },
      "cac-platforms:affordanceClass": {
        "@id": "cac-platforms:DistributionInfrastructure"
      },
      "cac-platforms:misuseDescription": "Persistent storage; harm continues past last contact"
    }
  ]
}
