      "@id": "caselinker:racketeering-investigation",
      "@type": "cacontology:CACInvestigation",
      "rdfs:label": "United States v. Lam et al. · D.D.C. 1:24-cr-00417 · RICO Social Engineering Enterprise",
      "cacontology:hasStep": [
        {"@id": "caselinker:racketeering-phase-gaming-formation"},
        {"@id": "caselinker:racketeering-phase-scheme-conditioning"},
        {"@id": "caselinker:racketeering-phase-role-specialization"},
