        {"@id": "caselinker:racketeering-phase-terminal"}
      ]
    },
    {
      "@id": "caselinker:racketeering-phase-gaming-formation",
      "@type": "cac-grooming:InitialContactPhase",
      "rdfs:label": "Online Gaming Community Formation",
      "rdfs:comment": "By October 2023 — Social Engineering Enterprise members formed friendships through online gaming platforms; Texas cohabitation and cyberfraud planning (second superseding indictment ¶¶23–24, 37a)",
      "cac-core:precedes": {"@id": "caselinker:racketeering-phase-scheme-conditioning"}
    },
    {
      "@id": "caselinker:racketeering-phase-scheme-conditioning",
      "@type": ["cac-grooming:ConditioningPhase", "cac-core:Phase"],
      "rdfs:label": "Scheme Conditioning & Database Targeting",
      "rdfs:comment": "October–December 2023 — database theft, email intrusions, and social-engineering attack combinations discussed and initiated; stolen crypto-related databases shared as targs (¶¶25, 33a, 37a–c)",
      "cac-core:precedes": {"@id": "caselinker:racketeering-phase-role-specialization"},
      "cac-core:conditioningMode": "criminal_skill_building"
    },
    {
      "@id": "caselinker:racketeering-phase-role-specialization",
      "@type": "cac-core:Phase",
      "rdfs:label": "Role Specialization",
      "rdfs:comment": "Early 2024 onward — differentiated enterprise roles: database hackers, organizers/target identifiers, callers/social engineers, money launderers, and IRL residential burglars for hardware wallets (¶¶25–32)",
      "cac-core:precedes": {"@id": "caselinker:racketeering-phase-theft-exploitation"}
    },
    {
      "@id": "caselinker:racketeering-phase-theft-exploitation",
      "@type": "cac-grooming:ExploitationPhase",
      "rdfs:label": "Social Engineering Thefts & IRL Break-ins",
      "rdfs:comment": "March–September 2024 — fraudulent VCE/email support calls, seed-phrase harvesting, and coordinated thefts including Victim-6 (~$14M) and Victim-7 (~$245M); July 2024 New Mexico hardware-wallet break-in (overt acts; forfeiture allegation)",
      "cac-core:precedes": {"@id": "caselinker:racketeering-phase-laundering-maintenance"}
    },
    {
      "@id": "caselinker:racketeering-phase-laundering-maintenance",
      "@type": "cac-grooming:MaintenancePhase",
      "rdfs:label": "Laundering, Luxury Spending & OpSec",
      "rdfs:comment": "2024–2025 — XMR/USDT laundering, crypto-to-cash exchangers, mansion rentals (LA/Miami/Hamptons), exotic-car fleet, straw owners; post–Sept 18 2024 Lam arrest Tangeman directed evidence destruction (¶¶33g–l; Tangeman sentencing memorandum)",
      "cac-core:precedes": {"@id": "caselinker:racketeering-phase-terminal"}
    },
    {
      "@id": "caselinker:racketeering-phase-terminal",
      "@type": "cac-grooming:ExploitationPhase",
      "rdfs:label": "Enterprise Harm Terminus",
      "rdfs:comment": "Terminal offense state — enterprise theft/laundering harm realized until Sept 2024 arrests cut the trajectory; multi-defendant superseding indictments and partial RICO pleas (e.g., Mehta, Tangeman, Yarally) occur after this offense terminus",
      "caselinker:is_terminal": true
    },
    {
      "@id": "caselinker:racketeering-affordance-gaming-conditioning",
