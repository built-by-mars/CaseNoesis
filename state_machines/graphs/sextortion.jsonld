      "@type": "cac-grooming:ExploitationPhase",
      "rdfs:label": "First Image — Asymmetry Created",
      "rdfs:comment": "CSAM obtained; victim cannot undo",
      "cac-core:precedes": {
        "@id": "caselinker:amin-phase-threat"
      }
    },
    {
      "@id": "caselinker:amin-phase-threat",
      "@type": "cac-sextortion:ThreatMechanism",
      "rdfs:label": "Threat Delivered",
      "rdfs:comment": "Threat to expose to social network",
      "cac-core:precedes": {
        "@id": "caselinker:amin-phase-coercion-cycle"
      }
    },
    {
      "@id": "caselinker:amin-phase-coercion-cycle",
      "@type": "cac-sextortion:CoercionCycle",
      "rdfs:label": "Self-Sustaining Coercion Loop",
      "rdfs:comment": "Daily quotas; each compliance produces new material extending leverage; account churn after bans",
      "cac-sextortion:sustainedBy": {
        "@id": "caselinker:amin-retained-imagery"
      },
      "cac-sextortion:cyclesBetween": [
        {
          "@id": "caselinker:amin-phase-threat"
        },
        {
          "@id": "caselinker:amin-phase-coercion-cycle"
        }
