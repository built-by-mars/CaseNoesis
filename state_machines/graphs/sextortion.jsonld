      "rdfs:label": "Retained CSAM collection powering coercion cycle"
    },
    {
      "@id": "caselinker:amin-phase-initial-contact",
      "@type": "cac-grooming:InitialContactPhase",
      "rdfs:label": "Impersonation Contact at Scale",
      "rdfs:comment": "80+ Snapchat, 40+ Instagram accounts",
      "cac-core:precedes": {
        "@id": "caselinker:amin-phase-trust-building"
      }
    },
    {
      "@id": "caselinker:amin-phase-trust-building",
      "@type": [
        "cac-grooming:ConditioningPhase",
        "cac-core:Phase"
      ],
      "rdfs:label": "Deception & Identity Fabrication",
      "rdfs:comment": "False peer identity",
      "cac-core:precedes": {
        "@id": "caselinker:amin-phase-exploitation-first"
      },
      "cac-core:conditioningMode": "deception"
    },
    {
