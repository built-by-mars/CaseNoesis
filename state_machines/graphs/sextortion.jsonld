    {
      "@id": "caselinker:amin-retained-imagery",
      "@type": "cac-core:Artifact",
      "rdfs:label": "Retained CSAM collection powering coercion cycle"
    },
    {
      "@id": "caselinker:amin-phase-initial-contact",
      "@type": "cac-grooming:InitialContactPhase",
      "rdfs:label": "Impersonation Contact at Scale",
      "rdfs:comment": "80+ Snapchat, 40+ Instagram accounts",
      "cac-core:precedes": {"@id": "caselinker:amin-phase-trust-building"}
    },
    {
      "@id": "caselinker:amin-phase-trust-building",
      "@type": "cac-grooming:TrustBuildingPhase",
      "rdfs:label": "Deception & Identity Fabrication",
      "rdfs:comment": "False peer identity",
      "cac-core:precedes": {"@id": "caselinker:amin-phase-exploitation-first"}
    },
    {
      "@id": "caselinker:amin-phase-exploitation-first",
      "@type": "cac-grooming:ExploitationPhase",
      "rdfs:label": "First Image — Asymmetry Created",
      "rdfs:comment": "CSAM obtained; victim cannot undo",
      "cac-core:precedes": {"@id": "caselinker:amin-phase-threat"}
    },
    {
      "@id": "caselinker:amin-phase-threat",
      "@type": "cac-sextortion:ThreatMechanism",
      "rdfs:label": "Threat Delivered",
      "rdfs:comment": "Threat to expose to social network",
      "cac-core:precedes": {"@id": "caselinker:amin-phase-coercion-cycle"}
    },
    {
      "@id": "caselinker:amin-phase-coercion-cycle",
      "@type": "cac-sextortion:CoercionCycle",
      "rdfs:label": "Self-Sustaining Coercion Loop",
      "rdfs:comment": "Daily quotas; each compliance produces new material extending leverage; account churn after bans",
      "cac-sextortion:sustainedBy": {"@id": "caselinker:amin-retained-imagery"},
      "cac-sextortion:cyclesBetween": [
        {"@id": "caselinker:amin-phase-threat"},
        {"@id": "caselinker:amin-phase-coercion-cycle"}
      ],
      "cac-sextortion:coercionCycleDemandType": "imagery_quota",
      "cac-sextortion:terminationCondition": "apprehension",
      "cac-core:precedes": {"@id": "caselinker:amin-phase-maintenance"}
    },
    {
      "@id": "caselinker:amin-phase-maintenance",
      "@type": "cac-grooming:MaintenancePhase",
      "rdfs:label": "Network Distribution & Recruitment",
      "rdfs:comment": "Material to co-conspirators gated behind harassment; victims recruit other victims",
      "cac-core:precedes": {"@id": "caselinker:amin-phase-terminal"}
    },
    {
      "@id": "caselinker:amin-phase-terminal",
      "@type": "cac-grooming:ExploitationPhase",
      "rdfs:label": "Perpetual Re-Contact",
      "rdfs:comment": "No closure; cycle ends only at apprehension or material removal"
    },
    {
      "@id": "caselinker:amin-account-replacement",
      "@type": "cac-grooming:AccountReplacementEvent",
      "rdfs:label": "Ban evasion account replacement",
      "rdfs:comment": "New account created after ban; victim told to reconnect or face exposure",
      "cac-grooming:triggeredBy": "platform_ban",
      "cac-grooming:resumesAt": {"@id": "caselinker:amin-phase-initial-contact"}
    },
