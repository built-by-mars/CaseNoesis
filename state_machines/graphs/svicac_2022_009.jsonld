  "@graph": [
    {
      "@id": "caselinker:svicac_2022_009-investigation",
      "@type": "cacontology:CACInvestigation",
      "rdfs:label": "United States v. Garcia-De Leon · N.D. Cal. 4:21-cr-00052 · 18 U.S.C. § 2252(a)(2)",
      "cacontology:hasStep": [
        {"@id": "caselinker:svicac_2022_009-phase-group-onset"},
        {"@id": "caselinker:svicac_2022_009-phase-gateway-verification"},
        {"@id": "caselinker:svicac_2022_009-phase-hogwarts-migration"},
        {"@id": "caselinker:svicac_2022_009-phase-governed-distribution"},
        {"@id": "caselinker:svicac_2022_009-phase-multi-room-maintenance"},
        {"@id": "caselinker:svicac_2022_009-phase-terminal"}
      ]
    },
    {
      "@id": "caselinker:svicac_2022_009-phase-group-onset",
      "@type": "cac-grooming:InitialContactPhase",
      "rdfs:label": "Kik CSAM Group Administration Onset",
      "rdfs:comment": "May 7, 2020 — defendants Garcia-De Leon and Darabi operated and administered a private Kik chat group through which members shared CSAM (indictment ¶6)",
      "cac-core:precedes": {"@id": "caselinker:svicac_2022_009-phase-gateway-verification"}
    },
    {
      "@id": "caselinker:svicac_2022_009-phase-gateway-verification",
      "@type": "cac-grooming:TrustBuildingPhase",
      "rdfs:label": "Gateway DM CSAM Verification",
      "rdfs:comment": "Defendants administered a separate gateway group requiring prospective members to send CSAM videos via Kik direct message before Hogwarts admission — builds verified member pool (indictment ¶7)",
      "cac-core:precedes": {"@id": "caselinker:svicac_2022_009-phase-hogwarts-migration"}
    },
    {
      "@id": "caselinker:svicac_2022_009-phase-hogwarts-migration",
      "@type": "cac-platforms:ChannelMigrationEvent",
      "rdfs:label": "Gateway → Hogwarts Room Migration",
      "rdfs:comment": "Defendants discussed and launched the Hogwarts child pornography room after gateway verification — children's popular-culture group name (indictment ¶8; sentencing memorandum)",
      "cac-platforms:fromPlatform": "Kik gateway verification room",
      "cac-platforms:toPlatform": "Kik Hogwarts CSAM room",
      "cac-platforms:migrationRationale": "capability_upgrade",
      "cac-platforms:occursBetween": [
        {"@id": "caselinker:svicac_2022_009-phase-gateway-verification"},
        {"@id": "caselinker:svicac_2022_009-phase-governed-distribution"}
      ],
      "cac-core:precedes": {"@id": "caselinker:svicac_2022_009-phase-governed-distribution"}
    },
    {
      "@id": "caselinker:svicac_2022_009-phase-governed-distribution",
      "@type": "cac-grooming:ExploitationPhase",
      "rdfs:label": "Hogwarts Governed CSAM Exchange",
      "rdfs:comment": "May 8–20, 2020 — at least 10 Kik users plus defendants actively distributed CSAM in Hogwarts at defendants' encouragement; 24-hour posting rules and under-ten content requirements; defendants posted and commented (sentencing memorandum; indictment ¶¶9–11)",
      "cac-core:precedes": {"@id": "caselinker:svicac_2022_009-phase-multi-room-maintenance"}
    },
    {
      "@id": "caselinker:svicac_2022_009-phase-multi-room-maintenance",
      "@type": "cac-grooming:MaintenancePhase",
      "rdfs:label": "Multi-Room Continued Administration",
      "rdfs:comment": "Through August 2020 search — defendant still administered Hogwarts plus 6–8 other Kik CSAM chatrooms; 600+ images on phone including 219 identified images and 3 videos from 89 victim series (sentencing memorandum)",
      "cac-core:precedes": {"@id": "caselinker:svicac_2022_009-phase-terminal"}
    },
    {
      "@id": "caselinker:svicac_2022_009-phase-terminal",
      "@type": "cac-grooming:ExploitationPhase",
      "rdfs:label": "Persistent Distributed CSAM Archive",
      "rdfs:comment": "Terminal state — gateway-verified Hogwarts circulation and multi-room administration sustain harm across 89 identified victim series and group member archives (sentencing memorandum)",
      "caselinker:is_terminal": true
    },
    {
      "@id": "caselinker:svicac_2022_009-affordance-onset-gateway",
      "@type": "cac-platforms:AffordanceMisuse",
      "cac-platforms:enablesTransitionFrom": {"@id": "caselinker:svicac_2022_009-phase-group-onset"},
      "cac-platforms:enablesTransitionTo": {"@id": "caselinker:svicac_2022_009-phase-gateway-verification"},
      "cac-platforms:affordanceClass": {"@id": "cac-platforms:ContactDiscovery"},
      "cac-platforms:misuseDescription": "Kik private-group admin controls enable co-defendant enterprise formation"
    },
    {
      "@id": "caselinker:svicac_2022_009-affordance-gateway-migration",
      "@type": "cac-platforms:AffordanceMisuse",
      "cac-platforms:enablesTransitionFrom": {"@id": "caselinker:svicac_2022_009-phase-gateway-verification"},
      "cac-platforms:enablesTransitionTo": {"@id": "caselinker:svicac_2022_009-phase-hogwarts-migration"},
      "cac-platforms:affordanceClass": {"@id": "cac-platforms:Coordination"},
      "cac-platforms:misuseDescription": "DM CSAM submission gate filters prospective members before interior room access"
    },
    {
      "@id": "caselinker:svicac_2022_009-affordance-migration-distribution",
      "@type": "cac-platforms:AffordanceMisuse",
      "cac-platforms:enablesTransitionFrom": {"@id": "caselinker:svicac_2022_009-phase-hogwarts-migration"},
      "cac-platforms:enablesTransitionTo": {"@id": "caselinker:svicac_2022_009-phase-governed-distribution"},
      "cac-platforms:affordanceClass": {"@id": "cac-platforms:DistributionInfrastructure"},
      "cac-platforms:misuseDescription": "Verified members migrate into Hogwarts open CSAM exchange"
    },
    {
      "@id": "caselinker:svicac_2022_009-affordance-distribution-maintenance",
      "@type": "cac-platforms:AffordanceMisuse",
      "cac-platforms:enablesTransitionFrom": {"@id": "caselinker:svicac_2022_009-phase-governed-distribution"},
      "cac-platforms:enablesTransitionTo": {"@id": "caselinker:svicac_2022_009-phase-multi-room-maintenance"},
      "cac-platforms:affordanceClass": {"@id": "cac-platforms:DistributionInfrastructure"},
      "cac-platforms:misuseDescription": "Posting rules and admin authority sustain multi-room Kik CSAM enterprise after May 2020 window"
    },
    {
      "@id": "caselinker:svicac_2022_009-affordance-maintenance-terminal",
      "@type": "cac-platforms:AffordanceMisuse",
      "cac-platforms:enablesTransitionFrom": {"@id": "caselinker:svicac_2022_009-phase-multi-room-maintenance"},
      "cac-platforms:enablesTransitionTo": {"@id": "caselinker:svicac_2022_009-phase-terminal"},
      "cac-platforms:affordanceClass": {"@id": "cac-platforms:DistributionInfrastructure"},
      "cac-platforms:misuseDescription": "600+ device images and parallel chatroom archives — no single seizure recovers all circulated material"
    }
  ]
