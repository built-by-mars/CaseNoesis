      },
      "noesis:affordanceClass": {
        "@id": "cac-platforms:CoercionLeverage"
      },
      "noesis:misuseDescription": "§ 875(d) threat sustains ongoing production demands"
    },
    {
      "@id": "caselinker:texas_ag_2019_013-affordance-escalation-cycle",
      "@type": "noesis:AffordanceMisuse",
      "noesis:enablesTransitionFrom": {
        "@id": "caselinker:texas_ag_2019_013-phase-escalating-demands"
      },
      "noesis:enablesTransitionTo": {
