      },
      "noesis:misuseDescription": "Harvested imagery converted to threat-to-disseminate leverage"
    },
    {
      "@id": "caselinker:texas_ag_2019_013-affordance-threat-escalation",
      "@type": "noesis:AffordanceMisuse",
