  "@graph": [
    {
      "@id": "caselinker:texas_ag_2019_013-investigation",
      "@type": "cacontology:CACInvestigation",
      "rdfs:label": "United States v. Duron · W.D. Tex. 5:19-cr-00804 · §§ 2251(a), 875(d)",
      "cacontology:hasStep": [
        {"@id": "caselinker:texas_ag_2019_013-phase-mobile-contact"},
        {"@id": "caselinker:texas_ag_2019_013-phase-grooming-coercion"},
        {"@id": "caselinker:texas_ag_2019_013-phase-first-production"},
        {"@id": "caselinker:texas_ag_2019_013-phase-threat-mechanism"},
        {"@id": "caselinker:texas_ag_2019_013-phase-escalating-demands"},
        {"@id": "caselinker:texas_ag_2019_013-phase-coercion-cycle"},
        {"@id": "caselinker:texas_ag_2019_013-phase-device-archive"},
        {"@id": "caselinker:texas_ag_2019_013-phase-terminal"}
      ]
    },
    {
      "@id": "caselinker:texas_ag_2019_013-phase-mobile-contact",
      "@type": "cac-grooming:InitialContactPhase",
      "rdfs:label": "Mobile App Chat Contact",
      "rdfs:comment": "February 2019: Duron in San Antonio contacted CV1 in Oregon, Wisconsin via mobile application chat rooms; interstate commerce element",
      "cac-core:precedes": {"@id": "caselinker:texas_ag_2019_013-phase-grooming-coercion"}
    },
    {
      "@id": "caselinker:texas_ag_2019_013-phase-grooming-coercion",
      "@type": "cac-grooming:TrustBuildingPhase",
      "rdfs:label": "Grooming & Production Solicitation",
      "rdfs:comment": "Defendant knew victim was a child; coerced her to produce images and videos of sexual activity via mobile applications",
      "cac-core:precedes": {"@id": "caselinker:texas_ag_2019_013-phase-first-production"}
    },
    {
      "@id": "caselinker:texas_ag_2019_013-phase-first-production",
      "@type": "cac-grooming:ExploitationPhase",
      "rdfs:label": "First CSAM Production & Receipt",
      "rdfs:comment": "Count 2 production and Count 3 receipt — depictions transmitted interstate and archived on defendant mobile devices through March 2019",
      "cac-core:precedes": {"@id": "caselinker:texas_ag_2019_013-phase-threat-mechanism"}
    },
    {
      "@id": "caselinker:texas_ag_2019_013-phase-threat-mechanism",
      "@type": "cac-sextortion:ThreatMechanism",
      "rdfs:label": "Threat to Disseminate",
      "rdfs:comment": "Defendant threatened to disseminate nude and erotic photographs to injure CV1's reputation and extort additional images; interstate communication",
      "cac-core:precedes": {"@id": "caselinker:texas_ag_2019_013-phase-escalating-demands"}
    },
    {
      "@id": "caselinker:texas_ag_2019_013-phase-escalating-demands",
      "@type": "cac-grooming:SexualizationPhase",
      "rdfs:label": "Escalating Explicit Demands",
      "rdfs:comment": "Under threat to disseminate, defendant demanded additional sexually explicit images and videos via mobile applications; prior compliance and leverage made refusal psychologically costly",
      "cac-core:precedes": {"@id": "caselinker:texas_ag_2019_013-phase-coercion-cycle"}
    },
    {
      "@id": "caselinker:texas_ag_2019_013-phase-coercion-cycle",
      "@type": "cac-sextortion:CoercionCycle",
      "rdfs:label": "Continued Extortion Demands",
      "rdfs:comment": "Continued mobile-app threats demanding more child pornography; Count 1 enticement and ongoing coercion through June 11, 2019",
      "cac-core:precedes": {"@id": "caselinker:texas_ag_2019_013-phase-device-archive"}
    },
    {
      "@id": "caselinker:texas_ag_2019_013-phase-device-archive",
      "@type": "cac-grooming:MaintenancePhase",
      "rdfs:label": "Device CSAM Archive",
      "rdfs:comment": "Defendant saved received CSAM on iPhone and Motorola devices subject to forfeiture",
      "cac-core:precedes": {"@id": "caselinker:texas_ag_2019_013-phase-terminal"}
    },
    {
      "@id": "caselinker:texas_ag_2019_013-phase-terminal",
      "@type": "cac-grooming:ExploitationPhase",
      "rdfs:label": "Persistent Retained CSAM Archive",
      "rdfs:comment": "Terminal state — produced and received depictions retained on forfeited iPhones and Motorola devices; coercion cycle ends at arrest; victim harm persists in archived material"
    },
    {
      "@id": "caselinker:texas_ag_2019_013-affordance-contact-grooming",
      "@type": "cac-platforms:AffordanceMisuse",
      "cac-platforms:enablesTransitionFrom": {"@id": "caselinker:texas_ag_2019_013-phase-mobile-contact"},
      "cac-platforms:enablesTransitionTo": {"@id": "caselinker:texas_ag_2019_013-phase-grooming-coercion"},
      "cac-platforms:affordanceClass": {"@id": "cac-platforms:ContactDiscovery"},
      "cac-platforms:misuseDescription": "Mobile chat apps enable pseudonymous interstate contact with minor victims"
    },
    {
      "@id": "caselinker:texas_ag_2019_013-affordance-grooming-production",
      "@type": "cac-platforms:AffordanceMisuse",
      "cac-platforms:enablesTransitionFrom": {"@id": "caselinker:texas_ag_2019_013-phase-grooming-coercion"},
      "cac-platforms:enablesTransitionTo": {"@id": "caselinker:texas_ag_2019_013-phase-first-production"},
      "cac-platforms:affordanceClass": {"@id": "cac-platforms:UnmonitoredCommunication"},
      "cac-platforms:misuseDescription": "Coercive messaging escalates to first compliant production"
    },
    {
      "@id": "caselinker:texas_ag_2019_013-affordance-production-threat",
      "@type": "cac-platforms:AffordanceMisuse",
      "cac-platforms:enablesTransitionFrom": {"@id": "caselinker:texas_ag_2019_013-phase-first-production"},
      "cac-platforms:enablesTransitionTo": {"@id": "caselinker:texas_ag_2019_013-phase-threat-mechanism"},
      "cac-platforms:affordanceClass": {"@id": "cac-platforms:CoercionLeverage"},
      "cac-platforms:misuseDescription": "Harvested imagery converted to threat-to-disseminate leverage"
    },
    {
      "@id": "caselinker:texas_ag_2019_013-affordance-threat-escalation",
      "@type": "cac-platforms:AffordanceMisuse",
      "cac-platforms:enablesTransitionFrom": {"@id": "caselinker:texas_ag_2019_013-phase-threat-mechanism"},
      "cac-platforms:enablesTransitionTo": {"@id": "caselinker:texas_ag_2019_013-phase-escalating-demands"},
      "cac-platforms:affordanceClass": {"@id": "cac-platforms:CoercionLeverage"},
      "cac-platforms:misuseDescription": "§ 875(d) threat sustains ongoing production demands"
    },
    {
      "@id": "caselinker:texas_ag_2019_013-affordance-escalation-cycle",
      "@type": "cac-platforms:AffordanceMisuse",
      "cac-platforms:enablesTransitionFrom": {"@id": "caselinker:texas_ag_2019_013-phase-escalating-demands"},
      "cac-platforms:enablesTransitionTo": {"@id": "caselinker:texas_ag_2019_013-phase-coercion-cycle"},
      "cac-platforms:affordanceClass": {"@id": "cac-platforms:UnmonitoredCommunication"},
      "cac-platforms:misuseDescription": "Each fulfilled demand resets the coercion loop for further production"
    },
    {
      "@id": "caselinker:texas_ag_2019_013-affordance-cycle-archive",
      "@type": "cac-platforms:AffordanceMisuse",
      "cac-platforms:enablesTransitionFrom": {"@id": "caselinker:texas_ag_2019_013-phase-coercion-cycle"},
