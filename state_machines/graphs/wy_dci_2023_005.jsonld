      "@type": "cac-grooming:MaintenancePhase",
      "rdfs:label": "2252A Distribution Window",
      "rdfs:comment": "February–April 2022 distribution conduct (Count 1) dismissed at plea; defendant agreed to $3,000 restitution for unpled conduct pursuant to plea agreement",
