        "cac-grooming:ConditioningPhase",
        "cac-core:Phase"
      ],
      "rdfs:label": "MV1 Grooming & Coercion",
      "rdfs:comment": "March–April 2022: defendant persuaded, induced, enticed, and coerced Minor Victim 1 via Internet and cellular networks to engage in sexually explicit conduct",
      "cac-core:precedes": {
        "@id": "caselinker:wy_dci_2023_005-phase-mv1-production"
      },
      "cac-core:conditioningMode": "compliance_shaping"
