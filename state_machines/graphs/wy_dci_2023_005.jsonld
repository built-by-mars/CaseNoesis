      "rdfs:label": "MV1 Completed Production",
      "rdfs:comment": "Count 2 conviction — production through April 28, 2022; visual depictions transported and transmitted using interstate Internet and cellular telephone networks",
      "cac-core:precedes": {
        "@id": "caselinker:wy_dci_2023_005-phase-distribution-window"
      }
    },
