      "rdfs:label": "ICAC Snapchat Cybertip Origin",
      "rdfs:comment": "WY DCI ICAC investigators received Cybertips from Snapchat (and linked Instagram accounts) identifying defendant Kyle Bradley Smith; registered sex offender with prior Sheridan County CR-2016-18 conviction",
      "cac-core:precedes": {
        "@id": "caselinker:wy_dci_2023_005-phase-mv1-grooming"
      }
    },
